<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<smartplaylist type="movies">
    <name>Recommended movies</name>
    <match>all</match>
    <rule field="rating" operator="greaterthan">7</rule>
    <rule field="playlist" operator="is">Movies Anime</rule>
    <limit>all</limit>
    <order direction="descending">random</order>
</smartplaylist>
