<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<smartplaylist type="movies">
    <name>Española Movies</name>
    <match>all</match>
    <rule field="country" operator="contain">
        <value>españa</value>
        <value>spain</value>
    </rule>
    <rule field="playlist" operator="isnot">Movies Anime</rule>
    <rule field="genre" operator="contain">anima</rule>
    <limit>all</limit>
    <order>title</order>
</smartplaylist>
