                    <param name="id" value="$PARAM[id]"/>
                    <param name="width" value="1188" />
                    <param name="height" value="$PARAM[height]" />
                    <param name="orientation" value="$PARAM[orientation]" />
                    <param name="layout" value="$PARAM[layout]" />
                    <param name="layoutwidth" value="$PARAM[layoutwidth]" />
                    <param name="layoutheight" value="$PARAM[layoutheight]" />
                    <param name="force_visible" value="!String.IsEmpty(Window(home).Property(CustomSearch))" />
                    <param name="force_tags" value="$PARAM[force_tags]" />
                    <param name="visibility" value="$PARAM[visibility]" />
                    <param name="widgetTags" value="$PARAM[widgetTags]" />
                </include>
        </definition>
    </include>

    <!-- Search Result Widget Top Label -->
    <include name="SearchResultWidgetTopLabel">
        <definition>
            <control type="grouplist" id="$PARAM[groupid]">
                <visible>Integer.IsGreater(Container($PARAM[id]).NumItems,0) | Container($PARAM[id]).IsUpdating</visible>
                <nested />
                <height>36</height>
                <orientation>horizontal</orientation>
                <usecontrolcoords>true</usecontrolcoords>
                <itemgap>2</itemgap>
                <control type="label">
                    <left>5</left>
                    <width>auto</width>
                    <label>$PARAM[label]</label>
                    <aligny>center</aligny>
                    <textcolor>FFEEEEEE</textcolor>
                    <font>27px_Bold</font>
                    <height>36</height>
                    <visible>Integer.IsGreater(Container($PARAM[id]).NumItems,0) | Container($PARAM[id]).IsUpdating</visible>
                </control>
                <control type="multiimage">
                    <top>26</top>
                    <width>24</width>
                    <height>10</height>
                    <aspectratio>keep</aspectratio>
                    <imagepath>spinner/search_widget_loader/</imagepath>
                    <timeperimage>250</timeperimage>
                    <pauseatend>500</pauseatend>
                    <fadetime>0</fadetime>
                    <visible>Container($PARAM[id]).IsUpdating</visible>
                </control>
            </control>
        </definition>
    </include>

