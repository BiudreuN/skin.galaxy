<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<smartplaylist type="tvshows">
    <name>Recommended kids</name>
    <match>all</match>
    <rule field="rating" operator="after">8</rule>
	<rule field="playlist" operator="isnot">Anime</rule>
	<rule field="playlist" operator="is">Kids tvshows</rule>
    <limit>200</limit>
    <order direction="descending">random</order>
</smartplaylist>
