					<param name="content_path" value="special://skin/playlists/movies/unwatched_movies.xsp"/>
					<param name="widget_header" value="Peliculas Sin Ver"/>
					<param name="widget_target" value="videos"/>
                    <param name="widget_limit" value="50"/>
