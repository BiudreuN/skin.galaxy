<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<smartplaylist type="tvshows">
    <name>Spotlight tvshows</name>
    <match>all</match>
    <rule field="genre" operator="doesnotcontain">anima</rule>
	<rule field="playlist" operator="isnot">TV Anime</rule>
    <limit>5</limit>
    <order direction="descending">random</order>
</smartplaylist>
