    <!-- Search Suggestions Container -->
    <include name="Search_Suggestions_Container">
        <param name="visibility" default="true" />
        <param name="left" default="137" />
        <param name="onback" default="9000" />
        <param name="onup" default="101" />
        <param name="ondown" default="noop" />
        <param name="onright" default="77777" />
        <param name="onleft" default="900" />
        <definition>
            <control type="list" id="$PARAM[id]">
                <nested/>
                <visible>$PARAM[visibility]</visible>
                <left>$PARAM[left]</left>
                <top>$PARAM[top]</top>
                <width>$PARAM[width]</width>
                <height>$PARAM[height]</height>
                <orientation>vertical</orientation>
                <onback>$PARAM[onback]</onback>
                <onup>$PARAM[onup]</onup>
                <ondown>$PARAM[ondown]</ondown>
                <onright>$PARAM[onright]</onright>
                <onleft>$PARAM[onleft]</onleft>
                <align>left</align>
                <itemlayout width="$PARAM[width]" height="65">
                    <control type="label">
                        <left>25</left>
                        <width>90%</width>
                        <height>100%</height>
                        <aligny>center</aligny>
                        <align>left</align>
                        <font>28px_Bold</font>
                        <textcolor>grey</textcolor>
                        <scroll>false</scroll>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                </itemlayout>
                <focusedlayout width="$PARAM[width]" height="65">
                    <control type="group">
                        <left>10</left>
                        <control type="image">
		        			<left>0</left>
		        			<top>0</top>
		        			<width>100%</width>
                            <height>100%</height>
			    			<texture border="10" background="true" colordiffuse="button_focus">lists/focus_border.png</texture>
			    			<visible>Control.HasFocus($PARAM[id])</visible>
			    		</control>
                        <control type="label">
                            <left>15</left>
                            <width>90%</width>
                            <height>100%</height>
                            <aligny>center</aligny>
                            <align>left</align>
                            <font>28px_Bold</font>
                            <textcolor>grey</textcolor>
                            <scroll>false</scroll>
                            <label>$INFO[ListItem.Label]</label>
                            <visible>!Control.HasFocus($PARAM[id])</visible>
                        </control>
                        <control type="label">
                            <left>15</left>
                            <width>90%</width>
                            <height>100%</height>
                            <aligny>center</aligny>
                            <align>left</align>
                            <font>28px_Bold</font>
                            <textcolor>FFEEEEEE</textcolor>
                            <scroll>false</scroll>
                            <label>$INFO[ListItem.Label]</label>
                            <visible>Control.HasFocus($PARAM[id])</visible>
                        </control>
                        <control type="button">
                            <visible>false</visible>
                            <onfocus condition="String.IsEmpty(Skin.String(CustomSearchTerm))">$PARAM[onitemfocus]</onfocus>
                            <onfocus condition="String.IsEmpty(Skin.String(CustomSearchTerm))">$PARAM[onitemfocus2]</onfocus>
                        </control>
                    </control>
                </focusedlayout>
            </control>
        </definition>
    </include>

	<include name="WidgetListSearch">
		<definition>
			<control type="panel" id="$PARAM[list_id]">
