<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<smartplaylist type="movies">
    <name>Movies Anime</name>
    <match>one</match>
	<rule field="genre" operator="contain">anime</rule>
    <rule field="tag" operator="contain">anime</rule>
    <limit>all</limit>
    <order direction="descending">random</order>
</smartplaylist>
