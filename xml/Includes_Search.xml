<?xml version="1.0" encoding="UTF-8"?>
<includes>
    <!-- VARS -->
    <variable name="SearchString">
        <value condition="!String.IsEmpty(Skin.String(CustomSearchTerm))">$INFO[Skin.String(CustomSearchTerm)]</value>
        <value condition="!String.IsEmpty(Window.Property(SuggestionPath)) + [ControlGroup(77777).HasFocus() | Control.HasFocus(1007) | [Control.HasFocus(900) + !String.IsEmpty(Window.Property(KeepSuggestions))]]">$INFO[Container(1007).ListItem.Label]</value>
    </variable>

    <variable name="EmptySearchResultsString">
        <value condition="Control.HasFocus(1007) + String.IsEmpty(Skin.String(CustomSearchTerm))">Sin Resultados</value>
        <value condition="String.IsEmpty(Skin.String(CustomSearchTerm)) + Window.IsActive(1107)">Buscar por Título, Género, Año, Estudio, Actor o Director</value>
        <value condition="String.IsEmpty(Skin.String(CustomSearchTerm))">a</value>
        <value>Sin Resultados</value>
    </variable>

    <variable name="SuggestionBorderColor">
        <value condition="Control.HasFocus(1007)">$INFO[Skin.String(ViewDetailsBorderFocusColor)]</value>
        <value>$INFO[Skin.String(BingieSecondaryTextColor)]</value>
    </variable>

    <!-- Search Auto-Complete Content Provider -->
    <variable name="SearchAutoCompleteContentProvider">
        <value condition="!String.IsEmpty(Skin.String(CustomSearchTerm)) + System.HasAddon(plugin.program.autocompletion)">plugin://plugin.program.autocompletion?info=autocomplete&amp;&amp;id=$INFO[Skin.String(CustomSearchTerm)]</value>
        <value condition="!String.IsEmpty(Skin.String(CustomSearchTerm)) + System.HasAddon(script.extendedinfo)">plugin://script.extendedinfo?info=autocomplete&amp;&amp;id=$INFO[Skin.String(CustomSearchTerm)]</value>
    </variable>

