<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<smartplaylist type="movies">
    <name>Bélica Movies</name>
    <match>all</match>
    <rule field="genre" operator="contain">
        <value>war</value>
        <value>bélica</value>
    </rule>
    <rule field="playlist" operator="isnot">Movies Anime</rule>
    <rule field="genre" operator="contain">anima</rule>
    <limit>all</limit>
    <order>title</order>
</smartplaylist>
