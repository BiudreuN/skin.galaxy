				</focusedlayout>
				<content sortby="$PARAM[sortby]" sortorder="$PARAM[sortorder]" target="$PARAM[target]" limit="$PARAM[limit]">$PARAM[content_path]</content>
				<content sortby="$PARAM[sortby]" sortorder="$PARAM[sortorder]" target="$PARAM[target]" limit="$PARAM[limit]">$PARAM[content_path2]</content>
			</control>
		</definition>
	</include>

    <!-- Search Container Template -->
    <include name="SearchContainerTemplate">
        <definition>
            <control type="panel" id="$PARAM[id]">
                <nested />
                <visible>Container($PARAM[id]).IsUpdating | Integer.IsGreater(Container($PARAM[id]).NumItems,0) | $PARAM[force_visible]</visible>
                <visible>$PARAM[visibility]</visible>
                <width>$PARAM[width]</width>
                <height>$PARAM[height]</height>
                <orientation>$PARAM[orientation]</orientation>
                <pagecontrol>$PARAM[pagecontrol]</pagecontrol>
                <scrolltime tween="quadratic">400</scrolltime>
                <preloaditems>4</preloaditems>
                <itemlayout width="$PARAM[layoutwidth]" height="$PARAM[layoutheight]">
                    <control type="group">
                        <width>$PARAM[layoutwidth]</width>
                        <height>$PARAM[layoutheight]</height>
                        <include>$PARAM[layout]Layout</include>
                        <control type="group">
                            <include content="$PARAM[layout]Tags">
                                <param name="force_tags" value="$PARAM[force_tags]" />
                                <param name="widgetTags" value="$PARAM[widgetTags]" />
                            </include>
                            <include>New_Episodes_Tag_Overlay</include>
                        </control>
                    </control>
                </itemlayout>
                <focusedlayout width="$PARAM[layoutwidth]" height="$PARAM[layoutheight]">
                    <control type="group">
                        <width>$PARAM[layoutwidth]</width>
                        <height>$PARAM[layoutheight]</height>
                        <include>$PARAM[layout]LayoutFocus</include>
                        <control type="group">
                            <include content="$PARAM[layout]Tags">
                                <param name="force_tags" value="$PARAM[force_tags]" />
                                <param name="widgetTags" value="$PARAM[widgetTags]" />
                            </include>
                            <include condition="String.IsEqual(Skin.String(HomeLayout),bingie)">New_Episodes_Tag_Overlay</include>
                        </control>
                    </control>
                </focusedlayout>
            </control>
        </definition>
    </include>

    <!-- Tag Overlays -->
    <include name="ThumbsViewTags">
        <include condition="!String.IsEqual(Skin.String(Widgets_DisplayTags),disable) | $PARAM[force_tags]">ThumbsTagOverlay</include>
        <include condition="String.IsEqual(Skin.String(Widgets_DisplayTags),auto)">LandscapeTagOverlayVisibility</include>
        <include content="$PARAM[widgetTags]" condition="String.IsEqual(Skin.String(Widgets_DisplayTags),override)">
            <param name="prefix" value="Landscape"/>
        </include>
    </include>

    <include name="SquarePosterPanelTags">
